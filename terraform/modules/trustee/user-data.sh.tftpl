#!/bin/bash
# Trustee instance initialization script with secret management
set -e

echo "=== Installing Trustee ==="

# Create secrets directory
mkdir -p /opt/trustee/secrets

# Install trustee (following official documentation)
yum install -y trustee jq openssl

# Create KBS repository directory
mkdir -p /opt/trustee/kbs/repository/default/local-resources/

# Common secrets (shared by all profiles) — lifecycle follows Trustee
echo "${disk_passphrase_base64}" | base64 -d > /opt/trustee/kbs/repository/default/local-resources/disk_passphrase
echo "${sshd_server_key_base64}" | base64 -d > /opt/trustee/kbs/repository/default/local-resources/sshd_server_key
echo "${sshd_server_pub_base64}" | base64 -d > /opt/trustee/kbs/repository/default/local-resources/sshd_server_key.pub

# Write KBS admin auth public key (KBS config references /etc/trustee/public.pub)
echo "${kbs_auth_pubkey_base64}" | base64 -d > /etc/trustee/public.pub

# Per-profile custom resources (e.g. openclaw_config) are uploaded dynamically
# via KBS API during 'make deploy/register PROFILE=xxx'.

# Generate certificates for Attestation Service
mkdir -p /tmp/certs

# Generate CA key and certificate
openssl ecparam -genkey -name prime256v1 -out /tmp/certs/as-ca.key
openssl req -x509 -sha256 -nodes -days 365 \
    -key /tmp/certs/as-ca.key \
    -out /tmp/certs/as-ca.pem \
    -subj "/O=Trustee CA" \
    -addext "keyUsage=critical,cRLSign,keyCertSign,digitalSignature"

# Generate AS key and certificate
openssl ecparam -genkey -name prime256v1 -out /tmp/certs/as.key
openssl req -new -key /tmp/certs/as.key -out /tmp/certs/as.csr -subj "/CN=Trustee/O=Trustee CA"
openssl x509 -req -in /tmp/certs/as.csr \
    -CA /tmp/certs/as-ca.pem \
    -CAkey /tmp/certs/as-ca.key \
    -CAcreateserial \
    -out /tmp/certs/as.pem \
    -days 365 \
    -extensions v3_req \
    -extfile <(echo -e "[v3_req]\nsubjectKeyIdentifier = hash") \
    -sha256

# Create full certificate chain
cat /tmp/certs/as.pem /tmp/certs/as-ca.pem > /tmp/certs/as-full.pem


if [ -n "$DEV_TRUSTEE" ]; then 
    # Create default policy for testing
    # WARNING: This policy skips attestation checks - NOT FOR PRODUCTION
    mkdir -p /opt/trustee/attestation-service/policies/opa
    cat > /opt/trustee/attestation-service/policies/opa/default.rego << 'POLICIES_EOF'
package policy

default executables := 3
default hardware := 2
default configuration := 2
default file_system := 2
POLICIES_EOF

else
    # Production policy — must match image/customize/files/trustee-opa-default.rego (local Trustee)
    mkdir -p /opt/trustee/attestation-service/policies/opa
    echo "${opa_default_rego_base64}" | base64 -d > /opt/trustee/attestation-service/policies/opa/default.rego
fi

# Generate Attestation Service configuration
cat /etc/trustee/as-config.json | jq '
    .attestation_token_broker.signer.cert_path="/tmp/certs/as-full.pem" |
    .attestation_token_broker.signer.key_path="/tmp/certs/as.key"
' > /tmp/config_with_cert.json
cp /tmp/config_with_cert.json /etc/trustee/as-config.json

# Check if running in container (no systemd)
if [ ! -d "/run/systemd/system" ]; then
    echo "=== Running in container, starting services manually ==="
    
    # Start RVPS service
    echo "Starting RVPS service..."
    /usr/bin/rvps --config /etc/trustee/rvps.json --address 127.0.0.1:50003 &
    RVPS_PID=$!
    sleep 1
    if ! kill -0 $RVPS_PID 2>/dev/null; then
        echo "ERROR: RVPS service failed to start"
        exit 1
    fi
    
    # Start gRPC Attestation Service
    echo "Starting gRPC Attestation Service..."
    /usr/bin/grpc-as --socket 0.0.0.0:50004 --config-file /etc/trustee/as-config.json &
    GRPC_AS_PID=$!
    sleep 1
    if ! kill -0 $GRPC_AS_PID 2>/dev/null; then
        echo "ERROR: gRPC Attestation Service failed to start"
        exit 1
    fi
    
    # Start restful Attestation Service
    echo "Starting restful Attestation Service..."
    /usr/bin/restful-as --socket 0.0.0.0:50005 --config-file /etc/trustee/as-config.json &
    RESTFUL_AS_PID=$!
    sleep 1
    if ! kill -0 $RESTFUL_AS_PID 2>/dev/null; then
        echo "ERROR: restful Attestation Service failed to start"
        exit 1
    fi
    
    # Start KBS service
    echo "Starting KBS service..."
    /usr/bin/kbs --config-file /etc/trustee/kbs-config.toml &
    KBS_PID=$!
    sleep 1
    if ! kill -0 $KBS_PID 2>/dev/null; then
        echo "ERROR: KBS service failed to start"
        exit 1
    fi
    
    # Start Trustee Gateway
    echo "Starting Trustee Gateway..."
    /usr/bin/trustee-gateway --config /etc/trustee/gateway.yml &
    GATEWAY_PID=$!
    sleep 1
    if ! kill -0 $GATEWAY_PID 2>/dev/null; then
        echo "ERROR: Trustee Gateway failed to start"
        exit 1
    fi
    
else
    echo "=== Running on system with systemd, starting Trustee service ==="
    # Enable and start Trustee service (following official documentation)
    systemctl daemon-reload
    systemctl enable trustee
    systemctl restart trustee
fi

# Reference values are registered dynamically via RVPS API when services
# are deployed (make register PROFILE=xxx). No static registration here.

echo "=== Trustee ready ==="
echo "Common secrets pre-loaded: disk_passphrase, sshd_server_key, sshd_server_key.pub"
echo "Per-profile custom resources will be uploaded via KBS API during deploy."
