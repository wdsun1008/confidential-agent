# Terraform variables for CAI deployment

# Availability zone (cn-beijing-l for Intel TDX g8i instances)
zone_id = "cn-beijing-l"

# Network Configuration
vpc_cidr         = "10.0.0.0/16"
vswitch_cidr     = "10.0.1.0/24"

# Project name
project_name = "cai"

# Image configuration: "prod" or "debug"
image_type = "debug"

# Security Group Allowed CIDR
security_group_allowed_cidr = "0.0.0.0/0"

# ==============================================================================
# Service profiles
# ==============================================================================
# The `services` map is auto-generated by the Makefile from profile.json files
# (see image/profiles/*/profile.json). You can also define it manually here.
#
# Usage:
#   make deploy PROFILE=openclaw   # adds openclaw to services and deploys
#   make deploy PROFILE=mcp        # adds mcp to services and deploys
#
# Manual example:
# services = {
#   openclaw = {
#     ip            = "10.0.1.20"
#     instance_type = "ecs.g8i.xlarge"
#     tdx           = true
#     disk_size     = 200
#     sg_ports      = ["22/22", "18789/18789"]
#   }
#   mcp = {
#     ip            = "10.0.1.30"
#     instance_type = "ecs.g8i.xlarge"
#     tdx           = true
#     disk_size     = 200
#     sg_ports      = ["22/22", "13001/13001"]
#   }
# }
