schema: confidential-agent/v1

service:
  id: cmaas
  ports: [8000]
  connect: []
  mcp_ports: [8000]
  app_service: cai-cmaas-mcp-proxy.service

build:
{{raw:BASE_IMAGE_LINE}}
  image_name: cmaas-memory
  resize: 30G
  with_network: true
  packages: [ca-certificates, curl, jq, nodejs, npm, tar, xz]
  scripts: [./install-cmaas.sh]
  variants:
    release:
      enabled: false
    debug:
      enabled: true

deploy:
  provider: aliyun
  image_variant: debug
  instance_type: {{yaml:INSTANCE_TYPE}}
  region: {{yaml:REGION}}
  zone_id: {{yaml:ZONE_ID}}
  disk_gb: {{raw:DISK_GB}}

attestation:
  tee: tdx
  mode: challenge
  reference_values: {{yaml:REFERENCE_VALUES}}
{{raw:REKOR_BLOCK}}

resources: {}
