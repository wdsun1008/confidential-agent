schema: confidential-agent/v1

service:
  id: mcp
  ports: [3001]
  connect: []
  app_service: cai-mcp-server.service

build:
{{raw:BASE_IMAGE_LINE}}
  image_name: mcp-agent
  resize: 30G
  with_network: true
  packages: [ca-certificates, curl, nodejs, npm]
  scripts: [./install-mcp.sh]
  variants:
    release:
      enabled: false
    debug:
      enabled: true

deploy:
  provider: aliyun
  image_variant: debug
  instance_type: {{yaml:INSTANCE_TYPE}}
  region: {{yaml:REGION}}
  zone_id: {{yaml:ZONE_ID}}
  disk_gb: 200

attestation:
  tee: tdx
  mode: challenge
  reference_values: {{yaml:REFERENCE_VALUES}}
{{raw:REKOR_BLOCK}}

resources: {}
