{
  "models": {
    "mode": "merge",
    "providers": {
      "bailian": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": {{json:DASHSCOPE_KEY}},
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.7-max",
            "name": "qwen3.7-max",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 65536
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "bailian/qwen3.7-max"
      }
    }
  },
  "plugins": {
    "enabled": true,
    "allow": ["cai-pep", "cai-a2a"],
    "entries": {
      "cai-pep": {
        "enabled": true,
        "config": {
          "socketPath": "/run/cai/pep.sock",
          "pepRequired": true,
          "defaultWorkdir": "/workspace"
        }
      },
      "cai-a2a": {
        "enabled": true,
        "config": {
          "peers": {}
        }
      }
    }
  },
  "channels": {},
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": {{json:OPENCLAW_GATEWAY_TOKEN}}
    },
    "http": {
      "endpoints": {
        "responses": {
          "enabled": true
        }
      }
    },
    "controlUi": {
      "enabled": true,
      "basePath": "/openclaw",
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": true
    }
  }
}
